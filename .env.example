#+#+#+#+------------------------------------------------------------------
# Backend base URLs (no secrets)
#
# IMPORTANT: To prevent DEV + PROD from sharing the same settings/ads storage,
# run two backends:
# - DEV backend configured to use DB: newspulse_dev
# - PROD backend configured to use DB: newspulse_prod
#
# Recommended: split DEV vs PROD backend origins.
# Local Next (localhost:3000) will use *_DEV.
# Vercel production deployment will use *_PROD.
NEXT_PUBLIC_API_BASE_DEV=http://localhost:3010
# NEXT_PUBLIC_API_BASE_PROD=https://YOUR_PROD_BACKEND_DOMAIN

# Back-compat (single base). Prefer *_DEV/*_PROD above.
# DEV example:
# NEXT_PUBLIC_API_BASE=http://localhost:3010
# PROD example:
# NEXT_PUBLIC_API_BASE=https://YOUR_PROD_BACKEND_DOMAIN

# Safety override (NOT recommended): allow dev to point at production backend.
# NEXT_PUBLIC_ALLOW_PROD_BACKEND_IN_DEV=false

# Back-compat aliases (optional). Prefer NEXT_PUBLIC_API_BASE_*.
# NEXT_PUBLIC_API_URL=http://localhost:3010
# NEXT_PUBLIC_BACKEND_URL=http://localhost:3010
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3010

# Simple single-base setup (used by some Pages Router SSR fetches as a safe fallback)
NEXT_PUBLIC_API_BASE_URL=https://newspulse-backend-real.onrender.com

# Developer/founder-only: show the public Settings gear + drawer on the homepage.
# Default should be false for production.
NEXT_PUBLIC_ENABLE_PUBLIC_SETTINGS_DRAWER=false

# Optional: force settings source for homepage modules/tickers.
# backend (default): use GET /api/public/settings (published)
# local: ignore published settings and use local-only controls (requires drawer flag true)
NEXT_PUBLIC_SETTINGS_SOURCE=backend

#+#+#+#+------------------------------------------------------------------
# Reporter Portal auth + email (required in production)
#
# REPORTER_PORTAL_AUTH_SECRET=replace-with-a-strong-random-secret
# NEXTAUTH_SECRET=optional-fallback-for-auth-secret
# RESEND_API_KEY=re_xxx
# REPORTER_PORTAL_RESEND_API_KEY=re_xxx
# REPORTER_PORTAL_FROM_EMAIL=News Pulse <reporter@your-domain.com>
# Supported sender aliases:
# RESEND_FROM_EMAIL=News Pulse <reporter@your-domain.com>
# REPORTER_PORTAL_EMAIL_FROM=News Pulse <reporter@your-domain.com>
# FROM_EMAIL=reporter@your-domain.com
# EMAIL_FROM=reporter@your-domain.com
# SMTP fallback supported by reporter auth route:
# REPORTER_PORTAL_SMTP_HOST=smtp.your-provider.com
# REPORTER_PORTAL_SMTP_PORT=587
# REPORTER_PORTAL_SMTP_USER=your-smtp-username
# REPORTER_PORTAL_SMTP_PASS=your-smtp-password
# REPORTER_PORTAL_SMTP_SECURE=false
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# MAIL_HOST=smtp.your-provider.com
# MAIL_PORT=587
# MAIL_USER=your-smtp-username
# MAIL_PASS=your-smtp-password
# MAIL_FROM=News Pulse <reporter@your-domain.com>
# NEXT_PUBLIC_SITE_URL=https://www.newspulse.co.in
# SITE_URL=https://www.newspulse.co.in

#+#+#+#+------------------------------------------------------------------
# Cloudinary (server-side) for cover image uploads
#
# Use with: POST/GET /api/admin/cloudinary/sign
# Client uploads directly to Cloudinary using the returned signature.
# Do NOT expose API secret to the browser.
#
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Protect server-side upload endpoint (/api/admin/cloudinary/upload) in production.
# Admin Panel should send: Authorization: Bearer <token>
NEWS_PULSE_ADMIN_UPLOAD_TOKEN=


